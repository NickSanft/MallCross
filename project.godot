; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters
;   format=value ; an event-based syntax used for arrays of items

config_version=5

[application]

config/name="MallCross"
config/description="First-person mall exploration with daily NYT-style crosswords. Solve to earn Woints, spend at mall stores on cosmetic and functional items."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[debug]

gdscript/warnings/exclude_addons=true
gdscript/warnings/untyped_declaration=1
gdscript/warnings/unsafe_method_access=1

[rendering]

renderer/rendering_method="forward_plus"
