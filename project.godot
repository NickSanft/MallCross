config_version=5

[application]

config/name="MallCross"
config/description="First-person mall exploration with daily NYT-style crosswords. Solve to earn Woints, spend at mall stores on cosmetic and functional items."
config/version="1.4.0"
run/main_scene="res://scenes/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

