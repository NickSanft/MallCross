[gd_resource type="AudioBusLayout" format=3]

; Three-bus layout introduced in v1.1.0:
;   Master  — top-level mix. The "Master volume" slider sets bus_volume_db here.
;   SFX     — gameplay sound effects (footsteps now, UI clicks + solve dings later).
;             Routed through Master.
;   Music   — ambient mall muzak + future jukebox tracks. Routed through Master.
;             Defaults -6 dB so music sits under SFX by design.
;
; Bus indices below match AudioServer.get_bus_index lookups in
; GameController._apply_settings.

[resource]
bus/0/name = &"Master"
bus/0/solo = false
bus/0/mute = false
bus/0/bypass_fx = false
bus/0/volume_db = 0.0
bus/0/send = &""

bus/1/name = &"SFX"
bus/1/solo = false
bus/1/mute = false
bus/1/bypass_fx = false
bus/1/volume_db = 0.0
bus/1/send = &"Master"

bus/2/name = &"Music"
bus/2/solo = false
bus/2/mute = false
bus/2/bypass_fx = false
bus/2/volume_db = -6.0
bus/2/send = &"Master"
