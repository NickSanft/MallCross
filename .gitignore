# Godot 4+ specific ignores
.godot/
/android/

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Build / export artifacts.
# export_presets.cfg IS tracked — release CI needs it to build Linux/Windows
# binaries headlessly. Treat it as source. Don't commit per-developer secrets
# (signing identities, ssh deploy hosts) inside it.
build/
export.cfg

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors / tooling
.directory
*~
*.tmp
.vscode/
.idea/

# CI artifacts
artifacts/

# Claude Code local files (commit .claude/settings.json if you want to share)
.claude/settings.local.json
.claude/*.lock
.claude/scheduled_tasks.lock
